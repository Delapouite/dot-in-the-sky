// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // General
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "auto_update": false,
  // Appearance
  "buffer_font_family": "Iosevka",
  "buffer_font_size": 10,
  "ui_font_family": "Iosevka",
  "ui_font_size": 10,
  "theme": {
    "mode": "dark",
    "light": "Dracula Light (Alucard)",
    "dark": "Dracula",
  },
  // Keymap
  "vim_mode": true,
  // Windows and Layout
  "tabs": {
    "git_status": true,
  },
  // Panels
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  // AI
  "disable_ai": true,
}
