// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // General
  "cli_default_open_behavior": "new_window",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "auto_update": false,
  // Appearance
  "buffer_font_family": "Iosevka",
  "buffer_font_size": 10,
  "ui_font_family": "Iosevka",
  "ui_font_size": 10,
  "theme": {
    "mode": "dark",
    "light": "Dracula Light (Alucard)",
    "dark": "Dracula",
  },
  // Keymap
  "helix_mode": false,
  "vim_mode": true,
  "which_key": {
    "enabled": true,
  },
  // Editor
  "code_lens": "on",
  // Windows and Layout
  "tabs": {
    "git_status": true,
  },
  // Panels
  "project_panel": {
    "bold_folder_labels": true,
    "diagnostic_badges": true,
    "dock": "left",
    "entry_spacing": "standard",
    "file_icons": true,
    "folder_icons": true,
    "git_status": true,
    "git_status_indicator": true,
    "hide_hidden": false,
    "hide_root": true,
    "starts_open": true,
  },
  "outline_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": null,
  },
  "lsp": {
    "clangd": {
      "binary": {},
    },
  },
  // AI
  "disable_ai": true,
}
